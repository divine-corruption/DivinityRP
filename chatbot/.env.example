# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# https://vyro.ai - Image generation API (OPTIONAL fallback).
# If XAI_API_KEY is set, image generation uses xAI Grok Imagine instead.
IMAGINE_API_KEY=****

# https://x.ai - xAI Grok API key (powers the chat engine, Character Forger,
# Story Arcs, DivinityAI, AND image generation via Grok Imagine). Required.
XAI_API_KEY=****

# Optional: override the xAI image model (default: grok-2-image)
# XAI_IMAGE_MODEL=grok-2-image

# --- Cloudflare R2 storage (preferred for all media) ---
# When configured, uploads + generated images are stored in R2.
# Falls back to Vercel Blob / local fs if these are unset.
R2_ACCOUNT_ID=****
# Or set the full endpoint instead of the account id:
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=****
R2_SECRET_ACCESS_KEY=****
R2_BUCKET=****
# Public base URL for the bucket (r2.dev or a custom domain). If omitted,
# media is served via time-limited presigned URLs.
# R2_PUBLIC_URL=https://media.yourdomain.com
# R2_PRESIGN_TTL=604800

# --- Cloudflare Workers (edge backend; see ../workers) ---
# Each is OPTIONAL. When a *_WORKER_URL is set the app routes through that worker;
# when unset it falls back to the app's built-in behavior (R2-direct / Blob /
# local fs / no enhancement). Deploy the workers in ../workers and paste URLs here.
#
# Shared HMAC secret used to sign/verify JWTs between the app and ALL workers.
# MUST be identical everywhere. If unset, the app reuses AUTH_SECRET.
# JWT_SECRET=****

# media-worker: image/video upload + per-character storage (R2-backed).
# MEDIA_WORKER_URL=https://divinityrp-media-worker.<acct>.workers.dev

# auth-worker: registration / login / JWT sessions.
# AUTH_WORKER_URL=https://divinityrp-auth-worker.<acct>.workers.dev

# backup-worker: versioned state snapshots + point-in-time recovery.
# BACKUP_WORKER_URL=https://divinityrp-backup-worker.<acct>.workers.dev

# enhance-worker: post-generation response enrichment (richer/lustier dialogue).
# ENHANCE_WORKER_URL=https://divinityrp-enhance-worker.<acct>.workers.dev
# Feature flags consumed by the app's /api/enhance route:
# ENABLE_RESPONSE_ENHANCEMENT=true
# RESPONSE_ENHANCEMENT_INTENSITY=normal   # subtle | normal | extreme
# Show the per-message "Enhance" button in the chat UI (client-visible flag):
# NEXT_PUBLIC_ENABLE_RESPONSE_ENHANCEMENT=true
