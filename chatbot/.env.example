# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# https://vyro.ai - Image generation API (OPTIONAL fallback).
# If XAI_API_KEY is set, image generation uses xAI Grok Imagine instead.
IMAGINE_API_KEY=****

# https://x.ai - xAI Grok API key (powers the chat engine, Character Forger,
# Story Arcs, DivinityAI, AND image generation via Grok Imagine). Required.
XAI_API_KEY=****

# Optional: override the xAI image model (default: grok-2-image)
# XAI_IMAGE_MODEL=grok-2-image

# --- Cloudflare R2 storage (preferred for all media) ---
# When configured, uploads + generated images are stored in R2. ALL FOUR of
# R2_ACCOUNT_ID (or R2_ENDPOINT), R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY and
# R2_BUCKET must be set or R2 is considered unconfigured and uploads fall back
# to Vercel Blob / local fs (which fails on read-only serverless filesystems).
R2_ACCOUNT_ID=****
# Or set the full endpoint instead of the account id:
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=****
R2_SECRET_ACCESS_KEY=****
R2_BUCKET=****
# Public base URL for the bucket (r2.dev or a custom domain). OPTIONAL.
# If omitted, media is served through the app's OWN stable, non-expiring
# /api/media/<key> route (recommended — no expiry, no extra setup). Only set
# this if you've enabled a public r2.dev domain or a custom domain on the bucket.
# R2_PUBLIC_URL=https://media.yourdomain.com
# R2_PRESIGN_TTL=604800

# Absolute base URL of THIS app (e.g. https://divinityrp.example.com). Used to
# build absolute /api/media URLs so server-side code can resolve them. On Vercel
# this is auto-derived from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL, so you
# usually don't need to set it. Set it for custom domains or non-Vercel hosts.
# APP_BASE_URL=https://divinityrp.example.com
